# ──────────────────────────────────────────────────────────────────────────────
# OperaBot Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/operabot_dev

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── File storage ─────────────────────────────────────────────────────────────
DOCUMENTS_STORAGE_PATH=./uploads/documents

# ──────────────────────────────────────────────────────────────────────────────
# LLM Provider — change LLM_PROVIDER to switch between providers.
# The rest of the code adapts automatically; only .env needs to change.
# ──────────────────────────────────────────────────────────────────────────────

# Supported values: ollama | groq | anthropic
LLM_PROVIDER=ollama

# ── Ollama (local, no API key, free) ─────────────────────────────────────────
# Default for development and on-premise deployments.
LLM_MODEL=llama3.2:1b
LLM_API_URL=http://localhost:11434/api/generate
LLM_TIMEOUT_SECONDS=300

# ── Groq (cloud, fast inference, generous free tier) ─────────────────────────
# 1. Set LLM_PROVIDER=groq
# 2. Get a free API key at https://console.groq.com/keys
# 3. Choose a model: llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768
#
# LLM_PROVIDER=groq
# LLM_MODEL=llama3-8b-8192
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# ── Anthropic Claude (cloud, best quality) ───────────────────────────────────
# 1. Set LLM_PROVIDER=anthropic
# 2. Get an API key at https://console.anthropic.com/
# 3. Choose a model: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
#
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
# ANTHROPIC_VERSION=2023-06-01
